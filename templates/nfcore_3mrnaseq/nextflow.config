// Minimal site config for nf-core/rnaseq
// Customize executor/queue/resources here as needed

params {
    genomes {
        'GRCh38' {
            fasta              = '/data/ref_genomes/GRCh38/src/GRCh38.primary_assembly.genome.fa'
            gtf                = '/data/ref_genomes/GRCh38/src/gencode.v49.primary_assembly.annotation.gtf'
            bed12              = '/data/ref_genomes/GRCh38/src/GRCh38.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCh38/src/GRCh38.transcripts.fa'

            star         = '/data/ref_genomes/GRCh38/indices/star'
            bowtie2      = '/data/ref_genomes/GRCh38/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCh38/indices/bwa/GRCh38'
            salmon       = '/data/ref_genomes/GRCh38/indices/salmon'
        }
        'GRCh38_with_ERCC' {
            fasta              = '/data/ref_genomes/GRCh38_with_ERCC/src/GRCh38_with_ERCC.fa'
            gtf                = '/data/ref_genomes/GRCh38_with_ERCC/src/GRCh38_with_ERCC.gtf'
            bed12              = '/data/ref_genomes/GRCh38_with_ERCC/src/GRCh38_with_ERCC.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCh38_with_ERCC/src/GRCh38_with_ERCC.transcripts.fa'

            star         = '/data/ref_genomes/GRCh38_with_ERCC/indices/star'
            bowtie2      = '/data/ref_genomes/GRCh38_with_ERCC/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCh38_with_ERCC/indices/bwa/GRCh38_with_ERCC'
            salmon       = '/data/ref_genomes/GRCh38_with_ERCC/indices/salmon'
        }
        'GRCm39' {
            fasta              = '/data/ref_genomes/GRCm39/src/GRCm39.primary_assembly.genome.fa'
            gtf                = '/data/ref_genomes/GRCm39/src/gencode.vM38.primary_assembly.annotation.gtf'
            bed12              = '/data/ref_genomes/GRCm39/src/GRCm39.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCm39/src/GRCm39.transcripts.fa'

            star         = '/data/ref_genomes/GRCm39/indices/star'
            bowtie2      = '/data/ref_genomes/GRCm39/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCm39/indices/bwa/GRCm39'
            salmon       = '/data/ref_genomes/GRCm39/indices/salmon'
        }
        'GRCm39_with_ERCC' {
            fasta              = '/data/ref_genomes/GRCm39_with_ERCC/src/GRCm39_with_ERCC.fa'
            gtf                = '/data/ref_genomes/GRCm39_with_ERCC/src/GRCm39_with_ERCC.gtf'
            bed12              = '/data/ref_genomes/GRCm39_with_ERCC/src/GRCm39_with_ERCC.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCm39_with_ERCC/src/GRCm39_with_ERCC.transcripts.fa'

            star         = '/data/ref_genomes/GRCm39_with_ERCC/indices/star'
            bowtie2      = '/data/ref_genomes/GRCm39_with_ERCC/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCm39_with_ERCC/indices/bwa/GRCm39_with_ERCC'
            salmon       = '/data/ref_genomes/GRCm39_with_ERCC/indices/salmon'
        }
        'mRatBN7.2' {
            fasta              = '/data/ref_genomes/mRatBN7.2/src/Rattus_norvegicus.GRCr8.dna.toplevel.fa'
            gtf                = '/data/ref_genomes/mRatBN7.2/src/Rattus_norvegicus.GRCr8.115.gtf'
            bed12              = '/data/ref_genomes/mRatBN7.2/src/mRatBN7.2.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/mRatBN7.2/src/mRatBN7.2.transcripts.fa'

            star         = '/data/ref_genomes/mRatBN7.2/indices/star'
            bowtie2      = '/data/ref_genomes/mRatBN7.2/indices/bowtie2'
            bwa          = '/data/ref_genomes/mRatBN7.2/indices/bwa/mRatBN7.2'
            salmon       = '/data/ref_genomes/mRatBN7.2/indices/salmon'
        }
        'mRatBN7.2_with_ERCC' {
            fasta              = '/data/ref_genomes/mRatBN7.2_with_ERCC/src/mRatBN7.2_with_ERCC.fa'
            gtf                = '/data/ref_genomes/mRatBN7.2_with_ERCC/src/mRatBN7.2_with_ERCC.gtf'
            bed12              = '/data/ref_genomes/mRatBN7.2_with_ERCC/src/mRatBN7.2_with_ERCC.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/mRatBN7.2_with_ERCC/src/mRatBN7.2_with_ERCC.transcripts.fa'

            star         = '/data/ref_genomes/mRatBN7.2_with_ERCC/indices/star'
            bowtie2      = '/data/ref_genomes/mRatBN7.2_with_ERCC/indices/bowtie2'
            bwa          = '/data/ref_genomes/mRatBN7.2_with_ERCC/indices/bwa/mRatBN7.2_with_ERCC'
            salmon       = '/data/ref_genomes/mRatBN7.2_with_ERCC/indices/salmon'
        }
        'Sscrofa11.1' {
            fasta              = '/data/ref_genomes/Sscrofa11.1/src/Sus_scrofa.Sscrofa11.1.dna.toplevel.fa'
            gtf                = '/data/ref_genomes/Sscrofa11.1/src/Sus_scrofa.Sscrofa11.1.115.gtf'
            bed12              = '/data/ref_genomes/Sscrofa11.1/src/Sscrofa11.1.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/Sscrofa11.1/src/Sscrofa11.1.transcripts.fa'

            star         = '/data/ref_genomes/Sscrofa11.1/indices/star'
            bowtie2      = '/data/ref_genomes/Sscrofa11.1/indices/bowtie2'
            bwa          = '/data/ref_genomes/Sscrofa11.1/indices/bwa/Sscrofa11.1'
            salmon       = '/data/ref_genomes/Sscrofa11.1/indices/salmon'
        }
        'Sscrofa11.1_with_ERCC' {
            fasta              = '/data/ref_genomes/Sscrofa11.1_with_ERCC/src/Sscrofa11.1_with_ERCC.fa'
            gtf                = '/data/ref_genomes/Sscrofa11.1_with_ERCC/src/Sscrofa11.1_with_ERCC.gtf'
            bed12              = '/data/ref_genomes/Sscrofa11.1_with_ERCC/src/Sscrofa11.1_with_ERCC.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/Sscrofa11.1_with_ERCC/src/Sscrofa11.1_with_ERCC.transcripts.fa'

            star         = '/data/ref_genomes/Sscrofa11.1_with_ERCC/indices/star'
            bowtie2      = '/data/ref_genomes/Sscrofa11.1_with_ERCC/indices/bowtie2'
            bwa          = '/data/ref_genomes/Sscrofa11.1_with_ERCC/indices/bwa/Sscrofa11.1_with_ERCC'
            salmon       = '/data/ref_genomes/Sscrofa11.1_with_ERCC/indices/salmon'
        }
        'GRCg7b' {
            fasta              = '/data/ref_genomes/GRCg7b/src/Gallus_gallus.bGalGal1.mat.broiler.GRCg7b.dna.toplevel.fa'
            gtf                = '/data/ref_genomes/GRCg7b/src/Gallus_gallus.bGalGal1.mat.broiler.GRCg7b.115.gtf'
            bed12              = '/data/ref_genomes/GRCg7b/src/GRCg7b.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCg7b/src/GRCg7b.transcripts.fa'

            star         = '/data/ref_genomes/GRCg7b/indices/star'
            bowtie2      = '/data/ref_genomes/GRCg7b/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCg7b/indices/bwa/GRCg7b'
            salmon       = '/data/ref_genomes/GRCg7b/indices/salmon'
        }
        'GRCg7b_with_ERCC' {
            fasta              = '/data/ref_genomes/GRCg7b_with_ERCC/src/GRCg7b_with_ERCC.fa'
            gtf                = '/data/ref_genomes/GRCg7b_with_ERCC/src/GRCg7b_with_ERCC.gtf'
            bed12              = '/data/ref_genomes/GRCg7b_with_ERCC/src/GRCg7b_with_ERCC.annotation.bed'
            transcript_fasta   = '/data/ref_genomes/GRCg7b_with_ERCC/src/GRCg7b_with_ERCC.transcripts.fa'

            star         = '/data/ref_genomes/GRCg7b_with_ERCC/indices/star'
            bowtie2      = '/data/ref_genomes/GRCg7b_with_ERCC/indices/bowtie2'
            bwa          = '/data/ref_genomes/GRCg7b_with_ERCC/indices/bwa/GRCg7b_with_ERCC'
            salmon       = '/data/ref_genomes/GRCg7b_with_ERCC/indices/salmon'
        }
    }
}

process {
    resourceLimits = [
        cpus: __EDIT_ME_MAX_CPUS__,
        memory: '__EDIT_ME_MAX_MEMORY__'
    ]
}
