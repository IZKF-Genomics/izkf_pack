// Minimal site config for nf-core/demultiplex.
// Runtime resource caps are passed through environment variables from run.sh.

plugins {
    id 'nf-schema@2.7.2'
}

def maxCpus = System.getenv('MAX_CPUS') ? System.getenv('MAX_CPUS') as int : 24
def maxMemory = System.getenv('MAX_MEMORY') ?: null
def demuxCpus = System.getenv('DEMUX_CPUS') ? System.getenv('DEMUX_CPUS') as int : maxCpus
def falcoCpus = System.getenv('FALCO_CPUS') ? System.getenv('FALCO_CPUS') as int : Math.max(1, Math.min(8, Math.floor(maxCpus / 4) as int))
def falcoMemoryGb = Math.max(6, falcoCpus * 3)
def falcoMaxForks = Math.max(1, Math.floor(maxCpus / falcoCpus) as int)
def mergeLanes = !System.getenv('MERGE_LANES') || System.getenv('MERGE_LANES').toLowerCase() in ['1', 'true', 'yes', 'on']

process {
    errorStrategy = 'retry'
    maxRetries = 1
    resourceLimits = [
        cpus: maxCpus,
        memory: maxMemory
    ]

    withName: BASES2FASTQ {
        cpus = demuxCpus
        memory = maxMemory
        ext.args = {
            def trimFastq = params.trim_fastq == true || params.trim_fastq.toString() == 'true'
            [
                "--skip-multi-qc",
                trimFastq ? "--settings 'R1AdapterTrim,true' --settings 'R2AdapterTrim,true'" : "",
            ].join(" ").trim()
        }
    }

    withName: BCLCONVERT {
        cpus = demuxCpus
        memory = maxMemory
        ext.args = {[
            meta.lane ? "--bcl-only-lane ${meta.lane}" : "",
            mergeLanes && !meta.lane ? "--no-lane-splitting true" : "",
            "--force",
            "--strict-mode true",
        ].join(" ").trim()}
    }

    withName: FALCO {
        cpus = falcoCpus
        memory = "${falcoMemoryGb}.GB"
        maxForks = falcoMaxForks
    }
}

report.overwrite = true
timeline.overwrite = true
trace.overwrite = true
dag.overwrite = true
